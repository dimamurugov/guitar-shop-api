# ===== Поставщик =====
# URL для скачивания CSV каталога
SUPPLIER_CSV_URL=https://supplier.example.com/catalog.csv

# ===== Tilda API =====
# Получить в личном кабинете Tilda: Настройки → API
TILDA_PUBLIC_KEY=your_tilda_public_key
TILDA_SECRET_KEY=your_tilda_secret_key

# ID проекта на Tilda (из URL: tilda.cc/projects/edit/XXXXXXX/)
TILDA_PROJECT_ID=123456

# ID страницы каталога на Tilda (из URL страницы в редакторе)
TILDA_PAGE_ID=654321

# ===== Сервер =====
PORT=3000

# Секрет для ручного запуска синхронизации через API
SYNC_SECRET=change_me_to_random_string

# ===== Расписание =====
# Cron-выражение: по умолчанию каждый день в 03:00
SYNC_CRON=0 3 * * *

# ===== Разделитель CSV =====
# Обычно запятая или точка с запятой
CSV_DELIMITER=,
